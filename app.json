{
  "expo": {
    "name": "Habibee",
    "slug": "habibee",
    "scheme": "com.lawrencejr.habibee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-black.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1f2428"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-black.png",
        "backgroundColor": "#1f2428"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lawrencejr.habibee",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon-transparent.png",
          "color": "#e56d2b"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52883c36-301b-4fdf-b88b-85b3bf6746fb"
      }
    },
    "owner": "lawrencejr"
  }
}
